{
  "name": "@xeno/channel-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --platform node --target node22 --out-dir dist --clean --no-splitting",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@xeno/shared-types": "*",
    "bullmq": "5.78.0",
    "dotenv": "^16.5.0",
    "hono": "^4.8.2",
    "ioredis": "5.10.1",
    "pino": "^9.7.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.31",
    "tsx": "^4.20.3",
    "tsup": "^8.5.0",
    "vitest": "^4.1.8"
  }
}

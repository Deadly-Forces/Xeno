{
  "name": "@xeno/crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "prisma generate && next build && tsup ws-server.ts --format cjs --platform node --target node22 --out-dir ws-dist --clean",
    "start": "next start -p 3000",
    "start:ws": "node ws-dist/ws-server.js",
    "lint": "next lint",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "vitest run",
    "seed": "tsx prisma/seed.ts",
    "model:train": "tsx scripts/train-model.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:deploy": "dotenv -e ../../.env -- prisma migrate deploy"
  },
  "dependencies": {
    "@openrouter/ai-sdk-provider": "0.7.5",
    "@prisma/client": "^6.10.1",
    "@tanstack/react-query": "^5.80.7",
    "@xeno/shared-types": "*",
    "ai": "^6.0.204",
    "argon2": "^0.44.0",
    "bullmq": "5.78.0",
    "clsx": "^2.1.1",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.5.0",
    "ioredis": "5.10.1",
    "lucide-react": "^0.515.0",
    "next": "^16.2.9",
    "next-auth": "4.24.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.3",
    "tailwind-merge": "^3.3.0",
    "ws": "^8.21.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.8.0",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.31",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.21",
    "dotenv-cli": "^8.0.0",
    "postcss": "^8.5.4",
    "prisma": "^6.10.1",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.5.1",
    "tsx": "^4.20.3",
    "vitest": "^3.2.4"
  }
}

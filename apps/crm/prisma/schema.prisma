generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Channel {
  WHATSAPP
  SMS
  EMAIL
  RCS
}

enum CampaignStatus {
  DRAFT
  RUNNING
  COMPLETED
  FAILED
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  OPENED
  READ
  CLICKED
}

enum SegmentCreator {
  ai
  human
}

enum UserRole {
  ADMIN
  MARKETER
  ANALYST
}

enum ExperimentStatus {
  DRAFT
  RUNNING
  COMPLETED
}

enum VariantKind {
  CONTROL
  TREATMENT
}

enum ConsentStatus {
  OPTED_IN
  OPTED_OUT
  UNKNOWN
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

model Organization {
  id                 String              @id @default(cuid())
  slug               String              @unique
  name               String
  createdAt          DateTime            @default(now())
  users              AppUser[]
  customers          Customer[]
  segments           Segment[]
  campaigns          Campaign[]
  auditLogs          AuditLog[]
  modelVersions      ModelVersion[]
  featureSnapshots   FeatureSnapshot[]
  driftReports       ModelDriftReport[]
  providerRateCards  ProviderRateCard[]
  deliveryCostEvents DeliveryCostEvent[]
  alerts             OperationalAlert[]
}

model AppUser {
  id           String    @id @default(cuid())
  email        String
  name         String
  passwordHash String
  role         UserRole  @default(MARKETER)
  organizationId String
  createdAt    DateTime  @default(now())
  auditLogs    AuditLog[]
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([organizationId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  organizationId String
  actorEmail String
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  actor      AppUser? @relation(fields: [actorId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([actorId])
  @@index([organizationId, createdAt])
}

model Customer {
  id                String              @id @default(cuid())
  externalId        String
  organizationId    String
  name              String
  email             String?
  phone             String?
  tags              String[]
  city              String
  ageGroup          String
  gender            String
  createdAt         DateTime            @default(now())
  lastOrderAt       DateTime?
  totalOrderValue   Decimal             @default(0) @db.Decimal(12, 2)
  totalOrders       Int                 @default(0)
  channelPreference Channel             @map("channel_preference")
  consentStatus     ConsentStatus       @default(UNKNOWN)
  consentUpdatedAt  DateTime?
  suppressedAt      DateTime?
  suppressionReason String?
  maxMessagesPerWeek Int                @default(3)
  orders            Order[]
  campaignMessages  CampaignMessage[]
  conversionEvents  ConversionEvent[]
  featureSnapshots  FeatureSnapshot[]
  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, externalId])
  @@unique([organizationId, email])
  @@unique([organizationId, phone])
  @@index([organizationId, lastOrderAt])
  @@index([totalOrderValue])
  @@index([city])
  @@index([channelPreference])
}

model Order {
  id          String            @id @default(cuid())
  customerId  String
  items       Json
  totalAmount Decimal           @db.Decimal(12, 2)
  status      String
  externalOrderId String?
  createdAt   DateTime          @default(now())
  customer    Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  conversions ConversionEvent[]

  @@index([customerId, createdAt])
  @@unique([customerId, externalOrderId])
}

model Segment {
  id            String     @id @default(cuid())
  name          String
  organizationId String
  description   String
  filterRules   Json
  customerCount Int        @default(0)
  createdAt     DateTime   @default(now())
  createdBy     SegmentCreator
  campaigns     Campaign[]
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model Campaign {
  id              String            @id @default(cuid())
  name            String
  segmentId       String
  organizationId  String
  channel         Channel
  messageTemplate String
  status          CampaignStatus    @default(DRAFT)
  scheduledAt     DateTime?
  createdAt       DateTime          @default(now())
  aiGenerated     Boolean           @default(false)
  failureReason   String?
  targetingMode   String            @default("ALL")
  targetPercentage Int              @default(100)
  useRecommendedChannel Boolean     @default(false)
  useRecommendedSendTime Boolean    @default(false)
  holdoutPercentage Int             @default(0)
  maxBudget        Decimal?         @db.Decimal(12, 2)
  failureRateThreshold Float        @default(0.15)
  minimumConversionRate Float       @default(0)
  guardrailPaused  Boolean          @default(false)
  guardrailReason  String?
  chaosEnabled     Boolean          @default(false)
  chaosFailureRate Float            @default(0)
  chaosLatencyMs   Int              @default(0)
  chaosDuplicateCallbacks Boolean   @default(false)
  chaosOutOfOrderCallbacks Boolean  @default(false)
  segment         Segment           @relation(fields: [segmentId], references: [id])
  messages        CampaignMessage[]
  experiment      CampaignExperiment?
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([segmentId])
  @@index([status])
}

model CampaignExperiment {
  id                String           @id @default(cuid())
  campaignId        String           @unique
  hypothesis        String
  status            ExperimentStatus @default(DRAFT)
  controlAllocation Int              @default(50)
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime         @default(now())
  campaign          Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  variants          CampaignVariant[]

  @@index([status])
}

model CampaignVariant {
  id              String             @id @default(cuid())
  experimentId    String
  name            String
  kind            VariantKind
  messageTemplate String
  experiment      CampaignExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  messages        CampaignMessage[]

  @@unique([experimentId, kind])
  @@index([experimentId])
}

model CampaignMessage {
  id                  String            @id @default(cuid())
  campaignId          String
  customerId          String
  personalizedMessage String
  status              MessageStatus     @default(QUEUED)
  failureReason       String?
  sentAt              DateTime?
  deliveredAt         DateTime?
  openedAt            DateTime?
  readAt              DateTime?
  clickedAt           DateTime?
  externalMessageId   String?           @unique
  variantId           String?
  decisionScore       Float?
  expectedRevenue     Decimal?          @db.Decimal(12, 2)
  churnRisk           Float?
  recommendedSendHour Int?
  actualChannel       Channel?
  scheduledFor        DateTime?
  recommendationReasons Json?
  isHoldout           Boolean           @default(false)
  campaign            Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer            Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  variant             CampaignVariant?  @relation(fields: [variantId], references: [id], onDelete: SetNull)
  conversions         ConversionEvent[]
  receipts            ReceiptEvent[]
  deliveryCosts       DeliveryCostEvent[]

  @@unique([campaignId, customerId])
  @@index([campaignId])
  @@index([status])
  @@index([externalMessageId])
  @@index([variantId])
  @@index([campaignId, decisionScore])
  @@index([campaignId, isHoldout])
}

model ReceiptEvent {
  id                String          @id @default(cuid())
  campaignMessageId String
  event             MessageStatus
  timestamp         DateTime
  createdAt         DateTime        @default(now())
  campaignMessage   CampaignMessage @relation(fields: [campaignMessageId], references: [id], onDelete: Cascade)

  @@unique([campaignMessageId, event])
  @@index([campaignMessageId])
}

model ConversionEvent {
  id                String          @id @default(cuid())
  campaignMessageId String
  customerId        String
  orderId           String
  revenue           Decimal         @db.Decimal(12, 2)
  createdAt         DateTime        @default(now())
  campaignMessage   CampaignMessage @relation(fields: [campaignMessageId], references: [id], onDelete: Cascade)
  customer          Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([campaignMessageId, orderId])
  @@index([customerId])
}

model FeatureSnapshot {
  id             String       @id @default(cuid())
  organizationId String
  customerId     String
  modelVersionId String?
  features       Json
  label          Boolean?
  capturedAt     DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  modelVersion   ModelVersion? @relation(fields: [modelVersionId], references: [id], onDelete: SetNull)

  @@index([organizationId, capturedAt])
  @@index([customerId, capturedAt])
}

model ModelVersion {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  version        String
  algorithm      String
  coefficients   Json
  calibration    Json
  metrics        Json
  trainedAt      DateTime     @default(now())
  active         Boolean      @default(false)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  snapshots      FeatureSnapshot[]
  driftReports   ModelDriftReport[]

  @@unique([organizationId, name, version])
  @@index([organizationId, active])
}

model ModelDriftReport {
  id             String       @id @default(cuid())
  organizationId String
  modelVersionId String
  populationSize Int
  featureDrift   Json
  scoreDrift     Float
  alert          Boolean      @default(false)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  modelVersion   ModelVersion @relation(fields: [modelVersionId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model ProviderRateCard {
  id             String       @id @default(cuid())
  organizationId String
  provider       String
  channel        Channel
  countryCode    String       @default("US")
  currency       String       @default("USD")
  unitCost       Decimal      @db.Decimal(12, 6)
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, channel, effectiveFrom])
}

model DeliveryCostEvent {
  id                String          @id @default(cuid())
  organizationId    String
  campaignMessageId String
  provider          String
  channel           Channel
  countryCode       String
  currency          String
  quantity          Int             @default(1)
  unitCost          Decimal         @db.Decimal(12, 6)
  totalCost         Decimal         @db.Decimal(12, 6)
  createdAt         DateTime        @default(now())
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaignMessage   CampaignMessage @relation(fields: [campaignMessageId], references: [id], onDelete: Cascade)

  @@unique([campaignMessageId, provider])
  @@index([organizationId, createdAt])
}

model OperationalAlert {
  id             String       @id @default(cuid())
  organizationId String
  severity       String
  source         String
  title          String
  details        Json?
  status         AlertStatus  @default(OPEN)
  notifiedAt     DateTime?
  createdAt      DateTime     @default(now())
  resolvedAt     DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, createdAt])
}
